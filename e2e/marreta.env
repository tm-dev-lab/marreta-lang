MARRETA_HOST=0.0.0.0
MARRETA_PORT=8080
MARRETA_REQUEST_LOG=false

# Feature flag exercised by /namespaces/feature.
MARRETA_FEATURE_BETA=true

# Auth (in-memory only): api_key hash is sha256 of "e2e-secret"; jwt uses an HMAC
# secret so no JWKS/network is needed.
MARRETA_API_KEY_HASH=sha256:88458bad1f357fbcc409825b5d9a83214f501304132f08bbcf6b0cd24b8629f9
MARRETA_JWT_SECRET=e2e-hmac-secret

# Base URL the http_client routes call back into (this same server).
MARRETA_SELF_URL=http://127.0.0.1:8080
