{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(task\\b.*|route\\s+(GET|POST|PUT|PATCH|DELETE)\\b.*|schema\\b.*|auth\\b.*\\{\\s*$|match\\b.*|fallback\\b.*|if\\b.*|else(\\s+if\\b.*)?|while\\b.*|transaction\\b.*|on\\s+(queue|topic)\\b.*|scenario\\b.*|when\\s+(GET|POST|PUT|PATCH|DELETE)\\b.*)$",
    "decreaseIndentPattern": "^\\s*(else(\\s+if\\b.*)?|fallback\\b.*)\\s*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*#.*$",
      "action": {
        "indentAction": "none"
      }
    }
  ]
}
