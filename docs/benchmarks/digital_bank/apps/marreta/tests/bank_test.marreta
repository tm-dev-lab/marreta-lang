# Provider-free scenario tests: every doc call is stubbed with `given`, so these run in memory
# with no MongoDB and no server. Used for the DX test feedback-loop measurement.

scenario "opens an account"
    given doc.accounts.save(anything) returns {
        _id: "acc-1", owner: "alice", balance: 0, currency: "BRL", active: true
    }

    when POST "/accounts" with { owner: "alice" }
    then status 201

scenario "rejects a withdrawal over the balance"
    given doc.accounts.find("acc-1") returns { _id: "acc-1", balance: 100, currency: "BRL" }

    when POST "/accounts/acc-1/withdraw" with { amount: 999 }
    then status 422

scenario "deposits into an account"
    given doc.accounts.find("acc-1") returns { _id: "acc-1", balance: 100, currency: "BRL" }
    given doc.accounts.update("acc-1", anything) returns { _id: "acc-1", balance: 150 }
    given doc.transactions.save(anything) returns { _id: "txn-1" }

    when POST "/accounts/acc-1/deposit" with { amount: 50 }
    then status 201
