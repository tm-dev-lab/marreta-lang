# Deps baked (incl. dev/test deps) so the timed run is the test execution only.
FROM node:22-slim@sha256:7af03b14a13c8cdd38e45058fd957bf00a72bbe17feac43b1c15a689c029c732
WORKDIR /app
COPY package.json package-lock.json tsconfig.json jest.config.js ./
RUN npm ci --silent
COPY src ./src
CMD ["npx", "jest", "--silent"]
