# MarretaLang environment config for the ecommerce example.
# Copy this file to .env or export these variables before running `marreta serve`.
# The docker-compose.yml in this directory starts a matching Postgres instance.

MARRETA_DB_PROVIDER=postgres
MARRETA_DB_HOST=localhost
MARRETA_DB_PORT=5432
MARRETA_DB_NAME=ecommerce
MARRETA_DB_USER=marreta
MARRETA_DB_PASSWORD=marreta
MARRETA_DOC_PROVIDER=mongodb
MARRETA_DOC_HOST=localhost
MARRETA_DOC_PORT=27017
MARRETA_DOC_NAME=ecommerce
