MARRETA_DB_PROVIDER=postgres
MARRETA_DB_HOST=127.0.0.1
MARRETA_DB_PORT=5434
MARRETA_DB_NAME=marreta
MARRETA_DB_USER=marreta
MARRETA_DB_PASSWORD=marreta

MARRETA_DOC_PROVIDER=mongodb
MARRETA_DOC_HOST=127.0.0.1
MARRETA_DOC_PORT=27019
MARRETA_DOC_NAME=marreta_functional
MARRETA_DOC_USER=marreta
MARRETA_DOC_PASSWORD=marreta-secret
MARRETA_DOC_AUTH_SOURCE=admin

MARRETA_QUEUE_PROVIDER=rabbitmq
MARRETA_QUEUE_HOST=127.0.0.1
MARRETA_QUEUE_PORT=5672
MARRETA_QUEUE_USER=guest
MARRETA_QUEUE_PASSWORD=guest

MARRETA_CACHE_PROVIDER=redis
MARRETA_CACHE_HOST=127.0.0.1
MARRETA_CACHE_PORT=6380
MARRETA_CACHE_PASSWORD=redis-secret
MARRETA_TIMEZONE=America/Sao_Paulo
MARRETA_LOG_LEVEL=debug
MARRETA_REQUEST_LOG=true
MARRETA_FEATURE_FUNCTIONAL_FLAG=true

# `internal_auth` never stores the raw API key in config. It stores only this
# hash. At request time, Marreta hashes/verifies the incoming `x-api-key` header
# and compares it with this value.
#
# The functional tests send: x-api-key: functional-secret
# For production, prefer an Argon2id PHC hash (`$argon2id$...`). This example
# uses `sha256:<hex>` only to keep the fixture deterministic and easy to inspect.
# To reproduce this fixture hash:
#   printf 'functional-secret' | sha256sum
MARRETA_AUTH_INTERNAL_API_KEY_HASH=sha256:657e236800ca148faa127a878413df90d48b4722e4f8c474a6024a6c890cd7e1

# JWT example configuration used by scenario tests. Real JWT signature
# validation is covered by Rust tests with local deterministic key fixtures.
MARRETA_AUTH_SCENARIO_JWKS_URL=https://issuer.example.test/.well-known/jwks.json
MARRETA_AUTH_SCENARIO_PUBLIC_KEY_FILE=tests/fixtures/auth/rsa_public_key.pem
MARRETA_AUTH_SCENARIO_HMAC_SECRET=functional-jwt-secret

MARRETA_PORT=3737
